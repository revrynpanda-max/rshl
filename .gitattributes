# GitHub Linguist — KAI language detection
#
# KAI's active engine is Rust (kai-rust/).
# Everything else is legacy: the src/ TypeScript was contributed by Claude,
# the root JS files are the original prototypes that have been ported to Rust.
# They stay in the repo for reference but the real engine is Rust.

# ── Vendored (tracked but not counted in language stats) ──────────────

# Claude's TypeScript source contribution
src/** linguist-vendored

# Build output
build/** linguist-vendored

# Legacy JavaScript prototypes (ported to Rust)
*.js linguist-vendored

# Eval/benchmark scripts (tooling, not the engine)
eval/** linguist-vendored

# ── Detected (counted in language stats) ──────────────────────────────

# The real KAI engine — Rust
kai-rust/src/**/*.rs linguist-detectable=true
kai-rust/src/**/*.rs linguist-vendored=false

# ── Data/docs (not counted) ───────────────────────────────────────────
*.txt linguist-documentation
*.json linguist-data
*.md linguist-documentation
*.bat linguist-vendored
*.cmd linguist-vendored
google-10000-english-usa.txt linguist-vendored
