{
  "name": "rshl",
  "version": "1.0.0",
  "description": "Sparse ternary HDC memory engine — deterministic local recall, no LLM, no API, no GPU required",
  "main": "rshl-core.js",
  "types": "rshl-core.ts",
  "exports": {
    ".": "./rshl-core.js",
    "./lattice": "./rshl-lattice.js"
  },
  "files": [
    "rshl-core.js",
    "rshl-core.ts",
    "rshl-lattice.js",
    "rshl_core.py",
    "examples/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "bench": "node bench.js",
    "bench:native": "npm run build-native && node bench.js",
    "build-native": "npx node-gyp configure build",
    "install": "node-gyp rebuild"
  },
  "optionalDependencies": {
    "node-addon-api": "^8.7.0"
  },
  "keywords": [
    "memory",
    "hdc",
    "hyperdimensional",
    "ternary",
    "sparse",
    "local-ai",
    "vector",
    "recall",
    "deterministic",
    "offline"
  ],
  "author": "Ryan (revrynpanda-max)",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "directories": {
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revrynpanda-max/rshl.git"
  },
  "gypfile": true,
  "bugs": {
    "url": "https://github.com/revrynpanda-max/rshl/issues"
  },
  "homepage": "https://github.com/revrynpanda-max/rshl#readme",
  "dependencies": {
    "node-gyp": "^12.2.0"
  }
}
