        "meta": {
          "source": "manual",
          "unresolved": false,
          "contradiction": 0,
          "novelty": 0
        }
      },
      {
        "text": "My logic is deterministic and based entirely on vector geometry, not language models.",
        "region": "reasoning",
        "strength": 1,
        "accessCount": 0,
        "dreamCount": 0,
        "lastAccessed": 0,
        "lastReplayed": 0,
