# Binaries (Local Only)
bin/
target/
*.exe
*.dll
*.so
*.dylib

# ── Personal identity — each user has their own, never shared ────────────────
data/identity.json

# ── Runtime memory & state — personal to each instance ──────────────────────
# These files hold learned memories, conversation history, and session state.
# They are local only. Each user builds their own memory pool from scratch.
data/*.json
data/*.jsonl
data/*.bin
!data/identity.template.json

# ── Analytics / plots / logs ──────────────────────────────────────────────────
*.csv
*.png
*.txt
*.log
reports/
scratch/
!scratch/.gitkeep

# ── Node (Legacy & Visualizer) ────────────────────────────────────────────────
node_modules/
visualizer/dist/
visualizer/node_modules/
legacy/typescript_engine/node_modules/

# ── Build Artifacts ──────────────────────────────────────────────────────────
build/
kai-build/
kai-build-*/
build_temp/

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vs/
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
Desktop.ini

# ── Assistant Artifacts & Session Tags (Local Only) ──────────────────────────
task.md
implementation_plan.md
walkthrough.md
KAI_COMMIT_GUIDE.md
KAI_SESSION_HANDOFF.md
rshl-bench-*.json
rshl-results.txt
